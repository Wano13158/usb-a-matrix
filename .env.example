PORT=3000
# Если backend запускается в Docker Compose, используйте http://tuwunel:6167
# Если backend запускается на хосте, обычно http://127.0.0.1:6167
MATRIX_BASE_URL=http://127.0.0.1:6167

# Optional: shared secret для Synapse Admin API fallback (не используется с Tuwunel).
# MATRIX_SHARED_SECRET=change_me

# Docker Compose variables for Tuwunel
TUWUNEL_SERVER_NAME=matrix.local
TUWUNEL_PORT=6167
TUWUNEL_ALLOW_REGISTRATION=true
# TUWUNEL_REGISTRATION_TOKEN=change_me
