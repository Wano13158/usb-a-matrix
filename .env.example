PORT=3000
# Если backend запускается в Docker Compose, используйте http://synapse:8008
# Если backend запускается на хосте, обычно http://127.0.0.1:8008
MATRIX_BASE_URL=http://127.0.0.1:8008

# Optional: Synapse shared secret for fallback registration when public registration is disabled.
# MATRIX_SHARED_SECRET=change_me

# Docker Compose variables for Synapse
SYNAPSE_SERVER_NAME=matrix.local
SYNAPSE_REPORT_STATS=no
